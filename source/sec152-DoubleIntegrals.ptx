    <exercise number="15.2.3">
      <p>
        Express the domain <m>\c{D}</m> in the following figure as both a vertically simple region and a horizontally simple region, and evaluate the integral of <m>f(x,y) = xy</m> over <m>\c{D}</m> as an iterated integral in two ways. 
      </p>
    </exercise>

    <exercise number="15.2.9">
      <p>
        Integrate <m>f(x,y) = x</m> over the region bounded by <m>y = x^2</m> and <m>y = x + 2</m>. 
      </p>
    </exercise>

    <exercise number="15.2.13">
      <p>
        Calculate the double integral of <m>f(x,y) = x + y</m> over the domain <m>\c{D} = \left\{(x,y) \mid x^2 + y^2 \leq 4, \, y \geq 0 \right\}</m>. 
      </p>
    </exercise>

    <exercisegroup>
    
      <introduction>
        <p>
          In the following exercises, compute the double integral of <m>f(x,y)</m> over the domain <m>\c{D}</m> indicated. 
        </p>
      </introduction>
    
      <exercise number="15.2.19">
        <p>
          <m>f(x,y) = x\, ; \qquad 0 \leq x \leq 1, \, 1 \leq y \leq e^{x^2}</m>
        </p>
      </exercise>

      <exercise number="15.2.23">
        <p>
          <m>f(x,y) = e^{x + y} \, \qquad \text{bounded by } y = x - 1, \, y = 12 - x, \, \text{for } 2 \leq y \leq 4</m>. 
        </p>
      </exercise>
    
    </exercisegroup>

    <exercise number="15.2.27">
      <p>
        Consider the double integral <m>\ds \int_4^9 \int_2^{\sqrt{y}} f(x,y) \, dx \, dy</m>. 
        Sketch the domain of integration and express as an iterated integral in the opposite order. 
      </p>
    </exercise>

    <exercise number="15.2.31">
      <p>
        Compute the integral of <m>f(x,y) = \lp \ln(y) \rp^{-1}</m> over the domain <m>\c{D}</m> bounded by <m>y = e^x</m> and <m>y = e^{\sqrt{x}}</m>. 
      </p>

      <hint>
        <p>
          Choose the order of integration that enables you to evaluate the integral. 
        </p>
      </hint>
    </exercise>

    <exercise number="15.2.35">
      <p>
        Consider the double integral <m>\ds \int_0^1 \int_{y = x}^1 xe^{y^3} \, dy \, dx</m>. 
        Sketch the domain of integration. 
        Then change the order of integration and evaluate. 
        Explain the simplification achieved by changing the order. 
      </p>
    </exercise>

    <exercise number="15.2.41">
      <p>
        Calculate the double integral of <m>f(x,y) = \dfrac{x}{y^2}</m> over the triangle indicated in the following figure. 
      </p>
    </exercise>

    <exercise number="15.2.47">
      <p>
        Find the volume of the region bounded by <m>z = 16 - y</m>, <m>z = y</m>, <m>y = x^2</m>, and <m>y = 8 - x^2</m>. 
      </p>
    </exercise>

    <exercise number="15.2.53">
      <p>
        Calculate the average value of <m>f(x,y) = e^{x + y}</m> on the square domain <m>[0,1] \times [0,1]</m>. 
      </p>
    </exercise>

    <exercise number="15.2.55">
      <p>
        Find the average height of the "ceiling" in the figure below defined by <m>z = y^2\sin(x)</m> for <m>0 \leq x \leq \pi</m> and <m>0 \leq y \leq 1</m>. 
      </p>
    </exercise>
  </worksheet>

